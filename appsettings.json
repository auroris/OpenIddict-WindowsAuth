{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",

  "IdentityServer": {
    "ServerUri": "*",
    "AccessTokenLifetime": "01:00:00",
    "IdentityTokenLifetime": "01:00:00",
    "AuthorizationCodeLifetime": "00:05:00",
    "UseForwardedHeaders": false,
    "PersistKeys": false,
    "Hosts": [ "http://localhost", "https://localhost", "http://myserver.com", "https://myserver.com", "https://oidcdebugger.com" ],
    "Clients": [
      { "ClientId": "my-public-app" },
      { "ClientId": "my-confidential-app", "ClientSecret": "changeme" }
    ],
    "Groups": [
      "MyServer .*",
      "MyServer Admin"
    ]
  }
}
